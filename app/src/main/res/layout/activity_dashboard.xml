<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="לוח בקרה ופעילות"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"
        android:textColor="#1A237E"/>

    <!-- Stats Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:strokeWidth="0dp"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:baselineAligned="false">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/text_total_items"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#3F51B5"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="סה''כ פריטים"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#424242"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/text_total_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₪0.00"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#388E3C"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="שווי המלאי"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#424242"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Search box - Clean Box Style -->
    <EditText
        android:id="@+id/edit_search_dashboard"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="חפש בהיסטוריית פעולות..."
        android:background="@drawable/quantity_background"
        android:paddingHorizontal="16dp"
        android:textColor="@android:color/black"
        android:textColorHint="#616161"
        android:layout_marginBottom="12dp"
        android:inputType="text" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp"
        android:gravity="center_vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_date_picker"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="בחר טווח תאריכים"
            app:cornerRadius="8dp"
            android:textAllCaps="false" />

        <ImageButton
            android:id="@+id/button_clear_filter"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#757575"
            android:contentDescription="נקה" />
    </LinearLayout>

    <TextView
        android:id="@+id/text_filter_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="מציג את כל הפעילויות"
        android:textSize="13sp"
        android:layout_marginBottom="12dp"
        android:textColor="#757575"
        android:textStyle="italic" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_transactions"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />

</LinearLayout>
