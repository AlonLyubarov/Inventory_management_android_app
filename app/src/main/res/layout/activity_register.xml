<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F8F9FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="רישום עובד חדש"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="32dp"
            android:textColor="#1A237E" />

        <!-- Name Field -->
        <EditText
            android:id="@+id/edit_text_display_name"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="שם מלא"
            android:inputType="textPersonName"
            android:background="@drawable/quantity_background"
            android:paddingHorizontal="16dp"
            android:textColor="@android:color/black"
            android:layout_marginBottom="16dp" />

        <!-- Email Field -->
        <EditText
            android:id="@+id/edit_text_email_reg"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="כתובת אימייל"
            android:inputType="textEmailAddress"
            android:background="@drawable/quantity_background"
            android:paddingHorizontal="16dp"
            android:textColor="@android:color/black"
            android:layout_marginBottom="16dp" />

        <!-- Password Field -->
        <EditText
            android:id="@+id/edit_text_password_reg"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="סיסמה (8+ תווים)"
            android:inputType="textPassword"
            android:background="@drawable/quantity_background"
            android:paddingHorizontal="16dp"
            android:textColor="@android:color/black"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="תפקיד העובד במערכת:"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#616161"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="#FFFFFF"
            app:strokeWidth="1dp"
            app:strokeColor="#E0E0E0"
            android:layout_marginBottom="32dp">
            <Spinner
                android:id="@+id/spinner_roles"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@android:drawable/btn_dropdown" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_register"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="צור חשבון לעובד"
            android:textSize="18sp"
            app:cornerRadius="12dp"
            android:backgroundTint="#1A237E"
            android:textAllCaps="false" />

    </LinearLayout>
</ScrollView>
