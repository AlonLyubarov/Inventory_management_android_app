<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="ניהול מלאי"
            app:titleCentered="true"
            app:titleTextColor="#1A237E" />
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Input Form Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="הוספת פריט למלאי"
                    android:textStyle="bold"
                    android:textColor="#1A237E"
                    android:layout_marginBottom="12dp" />

                <!-- Simple Clean Boxes with Labels Inside -->
                <AutoCompleteTextView
                    android:id="@+id/edit_text_name"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="שם הפריט"
                    android:background="@drawable/quantity_background"
                    android:paddingHorizontal="16dp"
                    android:textColor="@android:color/black"
                    android:textColorHint="#616161"
                    android:layout_marginBottom="12dp"
                    android:inputType="text" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/edit_text_sku"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:hint="מק''ט"
                        android:background="@drawable/quantity_background"
                        android:paddingHorizontal="16dp"
                        android:textColor="@android:color/black"
                        android:textColorHint="#616161"
                        android:inputType="text" />

                    <View android:layout_width="8dp" android:layout_height="match_parent"/>

                    <EditText
                        android:id="@+id/edit_text_brand"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:hint="מותג"
                        android:background="@drawable/quantity_background"
                        android:paddingHorizontal="16dp"
                        android:textColor="@android:color/black"
                        android:textColorHint="#616161"
                        android:inputType="text" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <EditText
                        android:id="@+id/edit_text_quantity"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:hint="כמות"
                        android:inputType="number"
                        android:background="@drawable/quantity_background"
                        android:paddingHorizontal="16dp"
                        android:textColor="@android:color/black"
                        android:textColorHint="#616161" />

                    <View android:layout_width="8dp" android:layout_height="match_parent"/>

                    <EditText
                        android:id="@+id/edit_text_price"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:hint="מחיר ₪"
                        android:inputType="numberDecimal"
                        android:background="@drawable/quantity_background"
                        android:paddingHorizontal="16dp"
                        android:textColor="@android:color/black"
                        android:textColorHint="#616161" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_add"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="16dp"
                    android:text="הוסף למלאי"
                    app:cornerRadius="12dp"
                    android:backgroundTint="#1A237E"
                    android:textAllCaps="false" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- No SwipeRefreshLayout here to prevent stuck spinning circle -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="20dp"
            android:clipToPadding="false" />

    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
